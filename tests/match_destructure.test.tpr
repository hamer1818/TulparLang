import "test";

// ---- Array destructuring -------------------------------------------------
func run_array_bind() {
    var r = match [10, 20] {
        [a, b] => a + b,
        _      => -1
    };
    assert_eq_int(r, 30);
}

func run_array_len_discrimination() {
    // Different arities select different arms; `_` is the fallback.
    assert_eq_str(classify([]), "empty");
    assert_eq_str(classify([7]), "one");
    assert_eq_str(classify([7, 8]), "two");
    assert_eq_str(classify([7, 8, 9]), "many");
}
func classify(json arr): str {
    return match arr {
        []     => "empty",
        [a]    => "one",
        [a, b] => "two",
        _      => "many"
    };
}

func run_array_literal_constraint() {
    // A literal element is a constraint, not a binding.
    var r = match [0, 99] {
        [0, x] => x,        // matches: first element is 0
        [a, b] => -1,
        _      => -2
    };
    assert_eq_int(r, 99);
}

func run_array_rest() {
    var r = match [1, 2, 3, 4] {
        [first, ..rest] => first + length(rest),  // 1 + 3
        _               => -1
    };
    assert_eq_int(r, 4);
}

// ---- Object (json) destructuring ----------------------------------------
func run_object_shorthand() {
    json p = {"x": 3, "y": 4};
    var r = match p {
        {x, y} => x * x + y * y,
        _      => -1
    };
    assert_eq_int(r, 25);
}

func run_object_constraint() {
    json u = {"role": "admin", "id": 7};
    var r = match u {
        {role: "admin", id} => id,
        {id}                => id + 1000,
        _                   => 0
    };
    assert_eq_int(r, 7);
}

// ---- Typed struct destructuring -----------------------------------------
type Point { int x; int y; }

func run_struct_bind() {
    Point p = { x: 5, y: 6 };
    var r = match p {
        Point{x, y} => x + y,
        _           => -1
    };
    assert_eq_int(r, 11);
}

func run_struct_field_constraint() {
    Point origin = { x: 0, y: 0 };
    var r = match origin {
        Point{x: 0, y: 0} => 1,   // both fields constrained
        Point{x, y}       => 2,
        _                 => 3
    };
    assert_eq_int(r, 1);
}

// ---- Nested destructuring -----------------------------------------------
func run_nested_object() {
    json shape = {"center": {"x": 3, "y": 4}, "radius": 10};
    var r = match shape {
        {center: {x, y}, radius} => x + y + radius,
        _                        => -1
    };
    assert_eq_int(r, 17);
}

func run_nested_array() {
    json grid = [[1, 2], [3, 4]];
    var r = match grid {
        [[a, b], [c, d]] => a + b + c + d,
        _                => -1
    };
    assert_eq_int(r, 10);
}

func run_nested_constraint() {
    json req = {"user": {"role": "admin", "id": 7}};
    var r = match req {
        {user: {role: "admin", id}} => id,   // constraint nested two levels deep
        {user: {id}}                => 0,
        _                           => -1
    };
    assert_eq_int(r, 7);
}

func run_nested_array_rest() {
    json pts = [[0, 0], [1, 1], [2, 2]];
    var r = match pts {
        [[0, 0], ..rest] => length(rest),    // nested literal constraint + rest
        _                => -1
    };
    assert_eq_int(r, 2);
}

print("=== match destructuring tests ===");
test("array bind", "run_array_bind");
test("array length discrimination", "run_array_len_discrimination");
test("array literal constraint", "run_array_literal_constraint");
test("array rest binding", "run_array_rest");
test("object shorthand bind", "run_object_shorthand");
test("object literal constraint", "run_object_constraint");
test("typed struct bind", "run_struct_bind");
test("typed struct field constraint", "run_struct_field_constraint");
test("nested object pattern", "run_nested_object");
test("nested array pattern", "run_nested_array");
test("nested constraint (deep)", "run_nested_constraint");
test("nested array + rest", "run_nested_array_rest");
test_summary();
