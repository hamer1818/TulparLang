import "test";

// Basic: an async function returns a promise; await yields its value.
async func double_it(int n) {
    return n * 2;
}

func run_basic() {
    var p = double_it(21);
    int r = await p;
    assert_eq_int(r, 42);
}

// await on a non-promise is the identity function.
func run_identity() {
    int z = await 7;
    assert_eq_int(z, 7);
}

// Non-blocking timer + interleaving: the 10ms coroutine settles before the
// 20ms one even though the 20ms task was spawned first.
async func after(int ms, int val) {
    await sleep_async(ms);
    return val;
}

func run_timer_order() {
    var slow = after(20, 100);
    var fast = after(10, 1);
    int f = await fast;   // fast first
    int s = await slow;
    assert_eq_int(f, 1);
    assert_eq_int(s, 100);
}

// A coroutine awaiting another coroutine (nested suspension).
async func inc(int x) {
    await sleep_async(2);
    return x + 1;
}
async func chain(int x) {
    int a = await inc(x);
    int b = await inc(a);
    return b;
}

func run_nested() {
    var c = chain(40);
    assert_eq_int(await c, 42);
}

// gather(...): await N coroutines concurrently, results in argument order
// (not completion order). The three tasks below settle 30/10/20ms apart.
async func wait_val(int ms, int val) {
    await sleep_async(ms);
    return val;
}

func run_gather_order() {
    var r = await gather(wait_val(30, 1), wait_val(10, 2), wait_val(20, 3));
    assert_eq_int(length(r), 3);
    assert_eq_int(r[0], 1);   // argument order, even though this settles last
    assert_eq_int(r[1], 2);
    assert_eq_int(r[2], 3);
}

// gather runs its children concurrently: 3×20ms should finish in ~20ms, not 60.
func run_gather_concurrent() {
    int t0 = time_ms();
    var r = await gather(wait_val(20, 1), wait_val(20, 1), wait_val(20, 1));
    int dt = time_ms() - t0;
    assert_eq_int(length(r), 3);
    assert(dt < 50, "gather should run children concurrently (~20ms, not ~60)");
}

// Non-promise arguments pass through unchanged.
func run_gather_passthrough() {
    var r = await gather(wait_val(5, 7), 99);
    assert_eq_int(r[0], 7);
    assert_eq_int(r[1], 99);
}

// gather called from inside a coroutine (nested suspension).
async func combo() {
    var inner = await gather(wait_val(10, 40), wait_val(20, 2));
    return inner[0] + inner[1];
}
func run_gather_nested() {
    assert_eq_int(await combo(), 42);
}

// ---- Rejection / error propagation ----------------------------------------
// An uncaught throw inside an async function rejects its promise; awaiting it
// re-raises the thrown value so it can be caught like any synchronous throw.
async func throw_after(int ms, str msg) {
    await sleep_async(ms);
    throw msg;
}

// Reject re-raises on the awaiting main thread.
func run_reject_caught() {
    str got = "none";
    try {
        await throw_after(2, "boom");
    } catch (e) {
        got = e;
    }
    assert_eq_str(got, "boom");
}

// Reject propagates out of a wrapping coroutine and is caught inside it.
async func wrap_catch() {
    try {
        await throw_after(2, "inner");
        return "no-throw";
    } catch (e) {
        return "caught:" + e;
    }
}
func run_reject_propagates() {
    assert_eq_str(await wrap_catch(), "caught:inner");
}

// A coroutine that catches its own throw fulfils normally (no rejection).
async func self_heal() {
    try {
        await throw_after(2, "x");
    } catch (e) {
        return "healed";
    }
    return "unreached";
}
func run_reject_self_heal() {
    assert_eq_str(await self_heal(), "healed");
}

// A rejecting gather child re-raises on the gather await.
async func ok_after(int ms, int v) {
    await sleep_async(ms);
    return v;
}
func run_gather_reject() {
    str got = "none";
    try {
        await gather(ok_after(5, 1), throw_after(2, "gboom"));
    } catch (e) {
        got = e;
    }
    assert_eq_str(got, "gboom");
}

print("=== async/await tests ===");
test("basic spawn + await", "run_basic");
test("await non-promise identity", "run_identity");
test("non-blocking timer ordering", "run_timer_order");
test("nested coroutines", "run_nested");
test("gather result ordering", "run_gather_order");
test("gather concurrency", "run_gather_concurrent");
test("gather non-promise passthrough", "run_gather_passthrough");
test("gather inside coroutine", "run_gather_nested");
test("reject re-raises on await", "run_reject_caught");
test("reject propagates through coroutine", "run_reject_propagates");
test("coroutine catches own throw", "run_reject_self_heal");
test("gather child rejection re-raises", "run_gather_reject");
test_summary();
