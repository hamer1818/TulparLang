import "test";

// password_hash / password_verify — PBKDF2-HMAC-SHA256.

func run_hash_verify() {
    str h = password_hash("hunter2");
    assert_contains(h, "pbkdf2_sha256$");
    assert_eq_bool(password_verify("hunter2", h), true);
    assert_eq_bool(password_verify("wrong", h), false);
}

// Random per-hash salt → two hashes of the same password differ, yet both verify.
func run_salt_unique() {
    str a = password_hash("samepw");
    str b = password_hash("samepw");
    assert_eq_bool(a == b, false);
    assert_eq_bool(password_verify("samepw", a), true);
    assert_eq_bool(password_verify("samepw", b), true);
}

// Malformed stored values return false, never crash.
func run_malformed() {
    assert_eq_bool(password_verify("x", "not-a-hash"), false);
    assert_eq_bool(password_verify("x", ""), false);
    assert_eq_bool(password_verify("x", "pbkdf2_sha256$bad"), false);
}

print("=== password KDF (pbkdf2-hmac-sha256) ===");
test("hash + verify", "run_hash_verify");
test("unique salt per hash", "run_salt_unique");
test("malformed stored value", "run_malformed");
test_summary();
