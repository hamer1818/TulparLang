// TEST 8: StringConcat
func stringConcat(int iterations): str {
    str result = "";
    int j = 0;
    while(j < iterations) {
        result = result + "a";
        j = j + 1;
    }
    return result;
}

print("Test 8: StringConcat(1K)");
