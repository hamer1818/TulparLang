// TEST 9: ArrayMemory
func arrayMemory(int size): int {
    array arr = [];
    int j = 0;
    while(j < size) {
        push(arr, j);
        j = j + 1;
    }
    int sum = 0;
    j = 0;
    while(j < size) {
        sum = sum + arr[j];
        j = j + 1;
    }
    return sum;
}

print("Test 9: ArrayMemory(10K)");
float start9 = clock_ms();
i = 0;
while(i < 1000) {
    result = arrayMemory(10000);
    i = i + 1;
}
float end9 = clock_ms();
float avg9 = (end9 - start9) / 1000.0;
print("Sure: " + toString(avg9) + " ms");
print("--------------------------------");

