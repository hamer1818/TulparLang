// TEST 6: Sieve of Eratosthenes (fixed-size array simulation)
func sieve(int n): int {
    // Simulate sieve with loop-based checking (no dynamic array)
    int count = 0;
    int j = 0;
    for(int i = 2; i <= n; i = i + 1) {
        int isPrime = 1;
        j = 2;
        while(j * j <= i) {
            if(i - (i / j) * j == 0) {
                isPrime = 0;
            }
            j = j + 1;
        }
        if(isPrime == 1) {
            count = count + 1;
        }
    }
    return count;
}

print("Test 6: Sieve(10K)");
float start6 = clock_ms();
i = 0;
while(i < 5000) {
    result = sieve(10000);
    i = i + 1;
}
float end6 = clock_ms();
float avg6 = (end6 - start6) / 5000.0;
print("Sure: " + toString(avg6) + " ms");
print("--------------------------------");

